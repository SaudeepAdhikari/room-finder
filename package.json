{
  "name": "room-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "admin",
    "backend"
  ],
  "scripts": {
    "build": "cross-env CI=false npm run build --workspace=client",
    "build:client": "cross-env CI=false npm run build --workspace=client",
    "build:admin": "cross-env CI=false npm run build --workspace=admin",
    "start:client": "npm start --workspace=client",
    "start:admin": "npm start --workspace=admin",
    "start:backend": "npm start --workspace=backend",
    "dev:backend": "npm run dev --workspace=backend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
